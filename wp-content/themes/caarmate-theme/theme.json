{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 2,
	"settings": {
		"layout": {
			"contentSize": "800px",
			"wideSize": "1200px"
		},
		"color": {
			"custom": false,
			"customGradient": false,
			"palette": [
				{
					"slug": "primary",
					"color": "#2c7a7b",
					"name": "Brand Teal"
				},
				{
					"slug": "secondary",
					"color": "#1a202c",
					"name": "Dark Slate"
				},
				{
					"slug": "background",
					"color": "#f7fafc",
					"name": "Off White"
				},
				{
					"slug": "text",
					"color": "#2d3748",
					"name": "Base Text"
				}
			]
		},
		"typography": {
			"customFontSize": false,
			"fluid": true,
			"fontSizes": [
				{
					"slug": "small",
					"size": "0.875rem",
					"name": "Small",
					"fluid": {
						"min": "0.8rem",
						"max": "0.875rem"
					}
				},
				{
					"slug": "medium",
					"size": "1rem",
					"name": "Medium",
					"fluid": {
						"min": "0.9rem",
						"max": "1rem"
					}
				},
				{
					"slug": "large",
					"size": "1.25rem",
					"name": "Large",
					"fluid": {
						"min": "1.1rem",
						"max": "1.25rem"
					}
				},
				{
					"slug": "x-large",
					"size": "1.75rem",
					"name": "X-Large",
					"fluid": {
						"min": "1.4rem",
						"max": "1.75rem"
					}
				},
				{
					"slug": "xx-large",
					"size": "2.5rem",
					"name": "XX-Large",
					"fluid": {
						"min": "1.8rem",
						"max": "2.5rem"
					}
				}
			]
		},
		"spacing": {
			"padding": true,
			"margin": true,
			"blockGap": true
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--background)",
			"text": "var(--wp--preset--color--text)"
		},
		"elements": {
			"link": {
				"color": {
					"text": "var(--wp--preset--color--primary)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--secondary)"
					}
				}
			},
			"heading": {
				"color": {
					"text": "var(--wp--preset--color--secondary)"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xx-large)"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)"
				}
			}
		}
	}
}
